# ── web-modupdater configuration ───────────────────────────────────────────
# Copy this file to ".env" and adjust. It is read both by docker compose
# (for variable substitution) and by the Node server (auto-loaded at startup).

# Target modpack repo (SSH form — the deploy key authenticates this).
MODPACK_REPO_SSH=git@github.com:Daledwin/modpack.git

# Allowed branches (comma-separated) and the default selected in the UI.
MODPACK_BRANCHES=staging,main
MODPACK_DEFAULT_BRANCH=staging

# Minecraft version this modpack targets — used ONLY to warn (never to block).
MODPACK_MC_VERSION=1.21.11

# Commit identity (neutral values are fine — this is a shared machine tool).
GIT_AUTHOR_NAME=modpack-tool
GIT_AUTHOR_EMAIL=modpack-tool@local

# ── Deploy key ──────────────────────────────────────────────────────────────
# Absolute path on the HOST to the PRIVATE deploy key (chmod 600), kept OUTSIDE
# this project. Generate it with:
#   ssh-keygen -t ed25519 -f deploy_key -N "" -C "modpack-tool"
# then add deploy_key.pub to the modpack repo's Deploy keys WITH WRITE ACCESS.
DEPLOY_KEY_PATH=/home/youruser/.ssh/modpack_deploy_key

# ── Local (non-Docker) extras ───────────────────────────────────────────────
# Where to keep the working clone / build scratch / normalized key.
# (In Docker these default to /data — leave unset there.)
# WORK_DIR=./.work
# MODPACK_CLONE_DIR=./.work/modpack-clone

# HTTP bind (defaults: 127.0.0.1:8787). Use HOST=0.0.0.0 inside containers.
# HOST=127.0.0.1
# PORT=8787
